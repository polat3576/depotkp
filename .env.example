# Backend server
PORT=3001
HOST=0.0.0.0
NODE_ENV=staging
CORS_ORIGIN=*

# Neon PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Web client (Vite)
VITE_API_URL=http://<linux-mint-local-ip>:3001/api

# Expo mobile
EXPO_PUBLIC_API_URL=http://<linux-mint-local-ip>:3001/api
