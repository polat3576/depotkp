{
  "info": {
    "name": "Depo Takip API",
    "description": "Restoran depo takip sistemi REST API koleksiyonu. Once 'Auth > Login (Admin)' calistir; token otomatik olarak {{admin_token}} degiskenine kaydedilir. Ayni sekilde 'Login (Staff)' -> {{staff_token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api" },
    { "key": "admin_email", "value": "admin@demorestoran.com" },
    { "key": "admin_password", "value": "Admin123!" },
    { "key": "staff_email", "value": "ahmet@demorestoran.com" },
    { "key": "staff_password", "value": "Staff123!" },
    { "key": "admin_token", "value": "" },
    { "key": "staff_token", "value": "" },
    { "key": "product_id", "value": "55555555-5555-5555-5555-555555555001" },
    { "key": "category_id", "value": "44444444-4444-4444-4444-444444444001" },
    { "key": "unit_id", "value": "33333333-3333-3333-3333-333333333001" },
    { "key": "supplier_id", "value": "66666666-6666-6666-6666-666666666002" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] } }
        },
        {
          "name": "GET /health/db",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/health/db", "host": ["{{base_url}}"], "path": ["health", "db"] } }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('admin_token', json.data.token);",
                  "  console.log('admin_token kaydedildi');",
                  "}",
                  "pm.test('Giris basarili', () => pm.response.code === 200);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('staff_token', json.data.token);",
                  "  console.log('staff_token kaydedildi');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{staff_email}}\",\n  \"password\": \"{{staff_password}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "POST /auth/users (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Yeni Calisan\",\n  \"email\": \"calisan@demorestoran.com\",\n  \"password\": \"Staff123!\",\n  \"role\": \"staff\"\n}" },
            "url": { "raw": "{{base_url}}/auth/users", "host": ["{{base_url}}"], "path": ["auth", "users"] }
          }
        }
      ]
    },
